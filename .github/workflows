name: Direct Deploy

on:
  push:
    branches: [master, develop]
  workflow_dispatch:

jobs:
  deploy-job:
    runs-on: self-hosted
    steps:
      - name: Git Pull and Deploy
        run: |
          cd /ssd/docker/upload_articles/upload_article
          git pull origin master
          npm install
          CI=false npm run build
          docker compose up -d --build
